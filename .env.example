# --- PostgreSQL (ใช้กับ docker-compose service `db`) ---
# ค่าเหล่านี้ส่งเข้า container Postgres เป็น POSTGRES_* และใช้ประกอบ DATABASE_URL ของ service `app`
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ku_prompt_learn

# Prisma / Next เมื่อรันบนเครื่อง (bun dev นอก Docker) — ต้องชี้ localhost + DB_PORT
# ให้ตรงกับ DB_USER / DB_PASSWORD / DB_NAME ด้านบน
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ku_prompt_learn"

# เมื่อรันแอปด้วย `docker compose up app` ไม่ต้องแก้ DATABASE_URL ในไฟล์นี้
# compose จะ override เป็น postgresql://USER:PASS@db:5432/DB_NAME อัตโนมัติ

# NextAuth / Auth.js — บังคับ: openssl rand -base64 32
# รันแอปด้วย Docker Compose ต้องใส่บรรทัดนี้ในไฟล์ชื่อ .env (ถ้าใส่แค่ใน .env.local อย่างเดียว container จะไม่ได้ค่า → MissingSecret)
AUTH_SECRET="แทนที่ด้วยสตริงยาวสุ่มอย่างน้อย 32 ตัว"

# Google OAuth (ไม่บังคับ) — ถ้าไม่ใส่ ปุ่ม «เชื่อมต่อด้วย Google» จะไม่แสดง
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# โปรดักชัน (Vercel ฯลฯ)
# AUTH_URL="https://your-domain.example"
