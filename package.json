{
  "name": "ku-prompt-learn",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:docker": "next dev --hostname 0.0.0.0 --port 3000 --webpack",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:migrate:resolve-summary-applied": "prisma migrate resolve --applied 20260414183000_add_summary",
    "db:migrate:resolve-summary-rolled-back": "prisma migrate resolve --rolled-back 20260414183000_add_summary",
    "db:push": "prisma db push",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@fontsource/noto-sans-thai": "^5.2.8",
    "@prisma/client": "6.19.0",
    "@react-pdf/renderer": "^4.3.3",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^1.8.0",
    "next": "16.2.2",
    "next-auth": "5.0.0-beta.30",
    "pdfjs-dist": "^5.6.205",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "prisma": "6.19.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
